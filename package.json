{
  "name": "@hanzogui/core-test",
  "version": "7.0.0",
  "license": "MIT",
  "author": {
    "name": "Nate Wienert"
  },
  "type": "module",
  "module": "dist/esm",
  "scripts": {
    "test:run": "vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts",
    "test:web": "GUI_TARGET=web vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.web.test.tsx",
    "test:ios": "TEST_NATIVE_PLATFORM=ios GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.ios.test.tsx",
    "test:native": "GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.native.test.tsx",
    "test:androidtv": "TEST_NATIVE_PLATFORM=androidtv GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.androidtv.test.tsx",
    "test:tvos": "TEST_NATIVE_PLATFORM=tvos GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.tvos.test.tsx",
    "test:update": "bun run test:native --update && bun run test:web --update"
  },
  "devDependencies": {
    "@hanzogui/core": "^7.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-native": "^12.9.0",
    "csstype": "^3.0.10",
    "react": ">=19",
    "typescript": "~5.9.2",
    "vitest": "4.0.4"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "publishConfig": {
    "access": "public"
  }
}